{
  "name": "labsgen-tiktok",
  "version": "0.19.0",
  "description": "TikTok Live Stream Key Generator for OBS from Streamlabs",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "main": "dist/main/index.js",
  "author": "Nhat Linh Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/antiantidev/labsgen-tiktok.git"
  },
  "scripts": {
    "start": "electron-vite preview",
    "dev": "cross-env CHOKIDAR_USEPOLLING=true electron-vite dev",
    "build": "electron-vite build",
    "release": "pnpm build && electron-builder --publish always",
    "postinstall": "pnpm exec electron-rebuild -f -w better-sqlite3",
    "preview": "electron-vite preview",
    "setup:chromedriver": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/download-chromedriver.ts",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test --experimental-strip-types",
    "typecheck": "pnpm run typecheck:main && pnpm run typecheck:preload && pnpm run typecheck:renderer",
    "typecheck:main": "pnpm exec tsc -p tsconfig.main.json --noEmit",
    "typecheck:preload": "pnpm exec tsc -p tsconfig.preload.json --noEmit",
    "typecheck:renderer": "pnpm exec tsc -p tsconfig.renderer.json --noEmit"
  },
  "build": {
    "appId": "com.labsgen-tiktok.app",
    "productName": "Labsgen Tiktok",
    "icon": "resources/icon.ico",
    "directories": {
      "output": "dist/installers"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "package.json",
      "node_modules/**/*",
      "node_modules/.pnpm/**/*",
      "drivers/**/*",
      "index.html"
    ],
    "extraResources": [
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/.pnpm/better-sqlite3@*/node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true,
      "uninstallDisplayName": "Labsgen Tiktok",
      "shortcutName": "Labsgen Tiktok",
      "deleteAppDataOnUninstall": true,
      "multiLanguageInstaller": false,
      "displayLanguageSelector": false,
      "warningsAsErrors": false
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "adm-zip": "^0.5.10",
    "better-sqlite3": "^12.6.2",
    "electron-updater": "^6.7.3",
    "framer-motion": "^12.33.0",
    "i18next": "^24.2.2",
    "lucide-react": "^0.563.0",
    "ms": "^2.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^15.4.0",
    "selenium-webdriver": "^4.40.0",
    "semver": "^7.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/electron": "^1.6.12",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "autoprefixer": "^10.4.24",
    "cross-env": "^7.0.3",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.2",
    "vite": "^7.3.1"
  }
}
